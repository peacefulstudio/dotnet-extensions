<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Description>OpenTelemetry tracing and metrics configuration for Peaceful Studio projects.</Description>
    <PackageTags>opentelemetry;otel;tracing;metrics;otlp;observability;telemetry;aspnetcore;instrumentation;extensions</PackageTags>
    <IsPackable>true</IsPackable>
    <NoWarn>$(NoWarn);NU5104</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="OpenTelemetry.Extensions.Hosting" />
    <PackageReference Include="OpenTelemetry.Instrumentation.AspNetCore" />
    <PackageReference Include="OpenTelemetry.Instrumentation.Http" />
    <PackageReference Include="OpenTelemetry.Instrumentation.GrpcNetClient" />
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol" />
  </ItemGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
</Project>
